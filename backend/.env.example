# MongoDB Connection URL
MONGO_URL=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/bloghub?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (change this to a strong secret in production)
JWT_SECRET=your_secure_jwt_secret_here_change_in_production

# CORS Configuration
CORS_ORIGIN=*
